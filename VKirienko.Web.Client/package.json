{
  "name": "vkirienko-site",
  "version": "1.0.0",
  "license": "MIT",
  "scripts": {
    "ng": "ng",
    "prestart": "run-s prebuild start:https",
    "start:https": "node aspnetcore-https",
    "start": "cross-env node start-dev.js",
    "prebuild": "",
    "build": "node --max-old-space-size=8192 ./node_modules/@angular/cli/bin/ng build",
    "watch": "ng build --watch --configuration development",
    "postbuild": "imagemin src/assets/img/* --plugin.webp.quality=100 --out-dir=dist/VKirienko.Web.Client/assets/img-min/",
    "eslint": "eslint \"src/**/*.ts\" --fix",
    "install:clean": "rm -rf node_modules/ && rm -rf package-lock.json && npm install && ng serve -o",
    "ncu": "npm-check-updates -u"
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "22.0.6",
    "@angular/common": "22.0.8",
    "@angular/compiler": "22.0.8",
    "@angular/core": "22.0.8",
    "@angular/forms": "22.0.8",
    "@angular/material": "^22.0.6",
    "@angular/platform-browser": "22.0.8",
    "@angular/platform-server": "22.0.8",
    "@angular/router": "22.0.8",
    "@fortawesome/angular-fontawesome": "^5.1.0",
    "@fortawesome/fontawesome-free": "^7.3.1",
    "@fortawesome/fontawesome-svg-core": "^7.3.1",
    "@fortawesome/free-brands-svg-icons": "^7.3.1",
    "@fortawesome/free-solid-svg-icons": "^7.3.1",
    "@microsoft/applicationinsights-web": "^3.4.3",
    "@microsoft/signalr": "^10.0.0",
    "@ngneat/until-destroy": "^10.0.0",
    "arrive": "^2.5.3",
    "bootstrap": "4.6.2",
    "bootstrap-material-design": "4.1.3",
    "bootstrap-notify": "3.1.3",
    "chartist": "1.5.0",
    "googleapis": "173.0.0",
    "hammerjs": "2.0.8",
    "jquery": "4.0.0",
    "moment": "2.30.1",
    "perfect-scrollbar": "1.5.6",
    "popper.js": "1.16.1",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@angular-devkit/schematics": "^22.0.8",
    "@angular/build": "^22.0.8",
    "@angular/cli": "^22.0.8",
    "@angular/compiler-cli": "22.0.8",
    "@angular/language-service": "22.0.8",
    "@eslint/config-inspector": "^3.1.0",
    "@eslint/js": "^10.0.1",
    "@types/bootstrap": "5.2.11",
    "@types/google.maps": "3.65.3",
    "@types/jquery": "4.0.1",
    "@types/node": "^26.1.1",
    "cross-env": "^10.1.0",
    "imagemin": "^9.0.1",
    "imagemin-cli": "^8.0.0",
    "imagemin-webp": "^8.0.0",
    "npm-check-updates": "^22.2.9",
    "npm-run-all2": "^9.0.2",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.65.0"
  },
  "browser": {
    "events": false,
    "http": false,
    "https": false,
    "url": false,
    "util": false
  }
}
